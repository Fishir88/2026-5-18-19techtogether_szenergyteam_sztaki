{
  "id": "real2sim",
  "name": "Real2Sim Bridge",
  "description": "OpenClaw tools for reading and controlling the local Real2Sim pose-to-robot bridge.",
  "version": "1.0.0",
  "activation": {
    "onStartup": false,
    "onCapabilities": ["tool"],
    "onConfigPaths": ["plugins.entries.real2sim"]
  },
  "contracts": {
    "tools": ["real2sim_state", "real2sim_command"]
  },
  "toolMetadata": {
    "real2sim_state": {
      "optional": true
    },
    "real2sim_command": {
      "optional": true
    }
  },
  "uiHints": {
    "apiPort": {
      "label": "Real2Sim API port",
      "help": "Port used by the local Real2Sim JSON API.",
      "placeholder": "8765"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiBaseUrl": {
        "type": "string",
        "default": "http://127.0.0.1:8765"
      }
    }
  }
}
